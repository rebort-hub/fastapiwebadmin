# ==================================
# 开发环境配置文件
# 复制为 env/.env.dev 后按需修改
# ==================================

ENVIRONMENT = "dev"

# ---------- 服务器 ----------
SERVER_HOST = "0.0.0.0"
SERVER_PORT = 8100
BASE_URL = "http://127.0.0.1:8100"

# ---------- 文档与 API ----------
DEBUG = True
TITLE = "FastapiwebAdmin API (dev)"
VERSION = "2.0"
API_PREFIX = "/api"
DOCS_URL = "/docs"
REDOC_URL = "/redoc"

# ---------- 数据库 ----------
SQL_DB_ENABLE = True
AUTO_CREATE_TABLES = True
AUTO_SEED_DATA = True
DATABASE_TYPE = "mysql"
DATABASE_HOST = "localhost"
DATABASE_PORT = 3306
DATABASE_USER = "root"
DATABASE_PASSWORD = "Rebort"
DATABASE_NAME = "fastapiwebadmin"
DATABASE_ECHO = False

# ---------- Redis ----------
REDIS_ENABLE = True
REDIS_HOST = "localhost"
REDIS_PORT = 6379
REDIS_USER = ""
REDIS_PASSWORD = ""
REDIS_DB_NAME = 1

# ---------- 认证 ----------
SECRET_KEY = "change-me-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES = 1440
CAPTCHA_ENABLE = True
CAPTCHA_EXPIRE_SECONDS = 300
REGISTER_ENABLE = True
REGISTER_EMAIL_CODE_ENABLE = True
REGISTER_DEFAULT_ROLE_IDS = [1]
EMAIL_HOST = "smtp.yeah.net"
EMAIL_PORT = 587
EMAIL_USERNAME = "pengjianbo2023@yeah.net"
EMAIL_PASSWORD = ""
EMAIL_FROM_ADDR = "pengjianbo2023@yeah.net"
EMAIL_FROM_NAME = "FastApiwebAdmin"
EMAIL_USE_SSL = True
EMAIL_CODE_EXPIRE_SECONDS = 120
OAUTH_FRONTEND_FALLBACK = "http://127.0.0.1:3000/login"
OAUTH_DEFAULT_ROLE_IDS = [1]
OAUTH_GITHUB_CLIENT_ID = ""
OAUTH_GITHUB_CLIENT_SECRET = ""
OAUTH_GITEE_CLIENT_ID = ""
OAUTH_GITEE_CLIENT_SECRET = ""
OAUTH_WECHAT_OPEN_APP_ID = ""
OAUTH_WECHAT_OPEN_APP_SECRET = ""
OAUTH_QQ_APP_ID = ""
OAUTH_QQ_APP_SECRET = ""

# ---------- 日志 ----------
LOGGER_LEVEL = "DEBUG"

# ---------- Celery ----------
CELERY_BROKER_URL = "redis://:redis@localhost:6379/5"
CELERY_RESULT_BACKEND = "redis://:redis@localhost:6379/5"
CELERY_BEAT_DB_URL = "mysql+pymysql://root:123456@localhost:3306/fastapiwebadmin?charset=utf8mb4"

# ---------- 跨域 ----------
CORS_ORIGINS = ["*"]
