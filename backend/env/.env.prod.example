# ==================================
# 生产环境配置文件
# 复制为 env/.env.prod 后按需修改
# ==================================

ENVIRONMENT = "prod"

# ---------- 服务器 ----------
SERVER_HOST = "0.0.0.0"
SERVER_PORT = 8100
BASE_URL = "http://127.0.0.1:8100"

# ---------- 文档与 API ----------
DEBUG = False
TITLE = "FastapiwebAdmin API"
VERSION = "2.0"
API_PREFIX = "/api"
LOGGER_LEVEL = "INFO"

# ---------- 数据库 ----------
SQL_DB_ENABLE = True
AUTO_CREATE_TABLES = True
AUTO_SEED_DATA = False
DATABASE_TYPE = "mysql"
DATABASE_HOST = "localhost"
DATABASE_PORT = 3306
DATABASE_USER = "root"
DATABASE_PASSWORD = "yourpassword"
DATABASE_NAME = "fastapiwebadmin"
DATABASE_ECHO = False

# ---------- Redis ----------
REDIS_ENABLE = True
REDIS_HOST = "localhost"
REDIS_PORT = 6379
REDIS_USER = ""
REDIS_PASSWORD = "yourpassword"
REDIS_DB_NAME = 4

# ---------- 认证 ----------
SECRET_KEY = "your-production-secret-key"
ACCESS_TOKEN_EXPIRE_MINUTES = 1440

# ---------- Celery ----------
CELERY_BROKER_URL = "redis://:yourpassword@localhost:6379/5"
CELERY_RESULT_BACKEND = "redis://:yourpassword@localhost:6379/5"
CELERY_BEAT_DB_URL = "mysql+pymysql://root:yourpassword@localhost:3306/fastapiwebadmin?charset=utf8mb4"

# ---------- 跨域（生产请改为具体域名）----------
CORS_ORIGINS = ["*"]
