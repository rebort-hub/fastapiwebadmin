# ==================================
# 开发环境配置文件
# 复制为 env/.env.dev 后按需修改
# ==================================

ENVIRONMENT = "dev"

# ---------- 服务器 ----------
SERVER_HOST = "0.0.0.0"
SERVER_PORT = 8100
BASE_URL = "http://127.0.0.1:8100"

# ---------- 文档与 API ----------
DEBUG = True
TITLE = "FastapiwebAdmin API (dev)"
VERSION = "2.0"
API_PREFIX = "/api"
DOCS_URL = "/docs"
REDOC_URL = "/redoc"

# ---------- 数据库 ----------
SQL_DB_ENABLE = True
AUTO_CREATE_TABLES = True
AUTO_SEED_DATA = True
DATABASE_TYPE = "mysql"
DATABASE_HOST = "localhost"
DATABASE_PORT = 3306
DATABASE_USER = "root"
DATABASE_PASSWORD = "123456"
DATABASE_NAME = "fastapiwebadmin"
DATABASE_ECHO = False

# ---------- Redis ----------
REDIS_ENABLE = True
REDIS_HOST = "localhost"
REDIS_PORT = 6379
REDIS_USER = ""
REDIS_PASSWORD = ""
REDIS_DB_NAME = 1

# ---------- 认证 ----------
SECRET_KEY = "change-me-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES = 1440

# ---------- 日志 ----------
LOGGER_LEVEL = "DEBUG"

# ---------- Celery ----------
CELERY_BROKER_URL = "redis://:redis@localhost:6379/5"
CELERY_RESULT_BACKEND = "redis://:redis@localhost:6379/5"
CELERY_BEAT_DB_URL = "mysql+pymysql://root:123456@localhost:3306/fastapiwebadmin?charset=utf8mb4"

# ---------- 跨域 ----------
CORS_ORIGINS = ["*"]
